{
    "name": "saturio/duckdb",
    "description": "PHP extension for DuckDB",
    "type": "php-ext",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Hernández-Marín",
            "email": "dani@satur.io"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "provide": {
        "ext-duckdb": "*"
    },
    "php-ext": {
        "configure-options": [
            {
                "name": "enable-duckdb",
                "description": "Enable duckdb support",
                "needs-value": false
            },
            {
                "name": "with-duckdb-dir",
                "description": "DuckDB installation prefix (contains include/duckdb.h and lib/libduckdb.*)",
                "needs-value": true
            }
        ]
    }
}
